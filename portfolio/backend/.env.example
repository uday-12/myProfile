# ── Database ──────────────────────────────────────────────────────────────────
# Neon pooled connection string (Dashboard → Connection Details → Pooled)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here

# Admin credentials used by the seed script
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_plain_text_password   # bcrypt-hashed by prisma/seed.js at seed time

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Dev:  http://localhost:5173
# Prod: https://your-portfolio.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
